{
  "name": "capforge",
  "productName": "CapForge",
  "version": "2.3.0",
  "description": "CapForge — Auto subtitle generator with word-by-word alignment",
  "main": "electron/main.js",
  "author": {
    "name": "FRScz",
    "email": "noreply@frscz.local"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dev:react": "electron-vite dev",
    "build:react": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "lint": "eslint src",
    "backend": "python -m uvicorn backend.main:app --host 127.0.0.1 --port 53421",
    "bundle:ffmpeg": "node scripts/bundle-ffmpeg.mjs",
    "dist": "npm run build:react && electron-builder",
    "dist:win": "npm run build:react && electron-builder --win",
    "dist:mac": "npm run build:react && electron-builder --mac",
    "dist:dir": "npm run build:react && electron-builder --dir",
    "release:mac": "bash scripts/release-mac.sh"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "lottie-web": "^5.13.0",
    "tree-kill": "^1.2.2",
    "wavesurfer.js": "^7.12.5"
  },
  "build": {
    "appId": "cz.frscz.capforge",
    "productName": "CapForge",
    "copyright": "Copyright © 2026 FRScz",
    "afterSign": "scripts/notarize.js",
    "afterPack": "scripts/sign-mac-python.js",
    "beforeBuild": "scripts/before-build.js",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "out/renderer/**/*",
      "backend/**/*.py",
      "backend/requirements.txt",
      "mcp_server/**/*.py",
      "mcp_server/knowledge/**/*.md",
      "!mcp_server/tests/**",
      "!backend/__pycache__/**",
      "!**/*.pyc",
      "!**/.venv/**",
      "!**/node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/**/*.d.ts",
      "!**/node_modules/**/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}"
    ],
    "asarUnpack": [
      "backend/**/*",
      "mcp_server/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "CapForge-Setup-${version}.${ext}",
      "extraResources": [
        {
          "from": "resources/bin-win",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/python",
          "to": "python",
          "filter": [
            "python-embed.zip"
          ]
        },
        {
          "from": "Fonts",
          "to": "Fonts",
          "filter": [
            "**/*.{ttf,otf,woff,woff2,TTF,OTF}"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon.icns",
      "artifactName": "CapForge-${version}.${ext}",
      "extraResources": [
        {
          "from": "resources/bin-mac",
          "to": "bin",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/python-mac-extracted",
          "to": "python"
        },
        {
          "from": "Fonts",
          "to": "Fonts",
          "filter": [
            "**/*.{ttf,otf,woff,woff2,TTF,OTF}"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CapForge",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "license": "LICENSE.txt",
      "deleteAppDataOnUninstall": false
    }
  }
}
