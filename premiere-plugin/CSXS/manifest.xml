<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  ExtensionBundleId="com.subforge.subtitles"
  ExtensionBundleVersion="1.0"
  Version="6.0">

  <ExtensionList>
    <Extension Id="com.subforge.subtitles" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="9.0"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.subforge.subtitles">
      <DispatchInfo>
        <Resources>
          <MainPath>./html/index.html</MainPath>
          <ScriptPath>./jsx/main.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>SubForge Subtitles</Menu>
          <Geometry>
            <Size>
              <Height>620</Height>
              <Width>420</Width>
            </Size>
            <MaxSize>
              <Height>900</Height>
              <Width>800</Width>
            </MaxSize>
            <MinSize>
              <Height>400</Height>
              <Width>360</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
